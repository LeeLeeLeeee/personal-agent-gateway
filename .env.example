# Common
AGENT_WEB_HOST=127.0.0.1
AGENT_WEB_PORT=8787
AGENT_WEB_TOKEN=replace-with-strong-random-token
PAG_DEV_ALLOWED_HOST=

# Workspace path examples:
# Windows: AGENT_WORKSPACE_ROOT=C:\Users\you\works
# macOS:   AGENT_WORKSPACE_ROOT=/Users/you/works
AGENT_WORKSPACE_ROOT=

AGENT_MODEL_PROVIDER=codex
AGENT_MODEL=default
AGENT_SESSION_DIR=./data/sessions
AGENT_APP_DB_PATH=./data/app.sqlite
AGENT_ARTIFACT_ROOT=./data/artifacts
AGENT_TEMP_DIR=./data/temp
AGENT_AUTH_DIR=./data/auth
AGENT_BACKUP_ROOT=./data/backups
AGENT_LOG_DIR=./data/logs
AGENT_AUTH_SETUP_TOKEN=
AGENT_AUTH_REQUIRE_TOKEN_AND_OTP=false
AGENT_AUTH_SESSION_ABSOLUTE_SECONDS=86400
AGENT_AUTH_SESSION_IDLE_SECONDS=3600
AGENT_ACCESS_MODE=restricted
AGENT_AUDIT_ENABLED=true
AGENT_OBSERVABILITY_ENABLED=true
AGENT_AUDIT_RETENTION_DAYS=90
AGENT_COOKIE_SECURE=false

# Leave blank to use platform defaults:
# Windows: codex.cmd
# macOS: codex
AGENT_CODEX_BIN=

# Leave blank to use platform defaults:
# Windows: claude.cmd
# macOS: claude
AGENT_CLAUDE_BIN=

AGENT_CODEX_SANDBOX=workspace-write
AGENT_CODEX_APPROVAL_POLICY=never
AGENT_CODEX_TIMEOUT_SECONDS=3600
AGENT_CODEX_IDLE_TIMEOUT_SECONDS=600

# Leave blank when ffmpeg/ffprobe are on PATH.
# Windows examples:
# AGENT_FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# AGENT_FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe
# macOS Homebrew examples:
# AGENT_FFMPEG_BIN=/opt/homebrew/bin/ffmpeg
# AGENT_FFPROBE_BIN=/opt/homebrew/bin/ffprobe
AGENT_FFMPEG_BIN=
AGENT_FFPROBE_BIN=

# Leave blank to use platform defaults:
# Windows: powershell
# macOS: screencapture
AGENT_CAPTURE_BIN=

AGENT_JOB_WORKER_CONCURRENCY=1
